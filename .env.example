# RepoLens environment configuration.
# Copy this file to `.env` and fill in the values you need.
# Environment variables take precedence over `.repolens.toml`.

# --- LLM backends -----------------------------------------------------------

# Required for the default Groq backend (free hosted tier, OpenAI-compatible).
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: only needed when `llm_backend = "anthropic"`.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: only needed when `llm_backend = "openai"`.
OPENAI_API_KEY=sk-...

# Optional: only needed when `llm_backend = "ollama"` (fully local, no API key).
OLLAMA_BASE_URL=http://localhost:11434

# --- Storage & runtime ------------------------------------------------------

# Where all indexes (vectors, BM25, symbol graph, metadata) are stored on disk.
REPOLENS_DATA_DIR=~/.repolens

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
REPOLENS_LOG_LEVEL=INFO
